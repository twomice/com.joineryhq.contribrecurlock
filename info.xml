<?xml version="1.0"?>
<extension key="com.joineryhq.contribrecurlock" type="module">
  <file>contribrecurlock</file>
  <name>Lock recurring contributions</name>
  <description>Prevent unprivleged users from canceling or editing recurring contributions (even their own).</description>
  <license>GPL-3.0</license>
  <maintainer>
    <author>Allen Shaw</author>
    <email>allen@JoineryHQ.com</email>
  </maintainer>
  <urls>
    <url desc="Main Extension Page">https://github.com/twomice/com.joineryhq.contribrecurlock</url>
    <url desc="Documentation">https://github.com/twomice/com.joineryhq.contribrecurlock</url>
    <url desc="Support">https://github.com/twomice/com.joineryhq.contribrecurlock/issues</url>
    <url desc="Licensing">http://www.gnu.org/licenses/gpl-3.0.html</url>
  </urls>
  <releaseDate>2021-04-20</releaseDate>
  <version>1.1</version>
  <develStage>alpha</develStage>
  <compatibility>
    <ver>5.51</ver>
  </compatibility>
  <comments/>
  <civix>
    <namespace>CRM/Contribrecurlock</namespace>
    <format>25.10.2</format>
  </civix>
  <mixins>
    <mixin>menu-xml@1.0.0</mixin>
    <mixin>scan-classes@1.0.0</mixin>
  </mixins>
  <classloader>
    <psr0 prefix="CRM_" path="."/>
    <psr4 prefix="Civi\" path="Civi"/>
  </classloader>
</extension>
